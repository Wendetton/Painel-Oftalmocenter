{
  "openapi": "3.0.1",
  "info": {
    "title": "ProDoctor Cloud - API Aberta",
    "version": "1.0",
    "notes": "Documentação salva localmente em 28/04/2026 a partir do upload feito pelo Fernando. Os endpoints utilizados pelo Painel Oftalmocenter são: POST /api/v1/Usuarios (lista de médicos), POST /api/v1/Agenda/BuscarPorStatusTipo (agendamentos do dia), GET /api/v1/Pacientes/Detalhar/{codigo} (idade do paciente). Headers obrigatórios: X-APIKEY, X-APIPASSWORD, X-APITIMEZONE (-03:00), X-APITIMEZONENAME (America/Sao_Paulo). Limite: 120 req/min."
  },
  "endpoints_utilizados_pelo_painel": {
    "buscarMedicos": {
      "method": "POST",
      "path": "/api/v1/Usuarios",
      "request": {
        "termo": "string opcional",
        "pagina": 1,
        "somenteAtivos": true,
        "quantidade": 5000
      },
      "response": {
        "payload": {
          "usuarios": [
            { "codigo": 0, "nome": "string" }
          ]
        }
      }
    },
    "buscarAgendamentosPorStatus": {
      "method": "POST",
      "path": "/api/v1/Agenda/BuscarPorStatusTipo",
      "request": {
        "pagina": 1,
        "quantidade": 5000,
        "periodo": { "dataInicial": "DD/MM/YYYY", "dataFinal": "DD/MM/YYYY" },
        "status": "EstadoAgendaConsultaBuscaRequest opcional",
        "tipo": "TipoAgendamentoBuscaRequest opcional",
        "usuarios": [{ "codigo": 0 }],
        "locaisProDoctor": [{ "codigo": 0 }],
        "procedimentos": null,
        "paciente": null
      },
      "response": {
        "payload": {
          "agendamentos": [
            {
              "localProDoctor": { "codigo": 0, "nome": "string" },
              "usuario": { "codigo": 0, "nome": "string" },
              "data": "DD/MM/YYYY",
              "hora": "HH:mm",
              "paciente": { "codigo": 0, "nome": "string" },
              "complemento": "string",
              "estadoAgendaConsulta": {
                "horaCompareceu": "HH:mm",
                "horaAtendimento": "HH:mm",
                "horaAtendido": "HH:mm",
                "compareceu": false,
                "atendimento": false,
                "atrasado": false,
                "exameSituacao": false,
                "atendido": false,
                "faltou": false
              },
              "tipoAgendamento": {
                "consulta": false,
                "retorno": false,
                "exame": false,
                "cirurgia": false,
                "compromisso": false,
                "teleconsulta": false
              },
              "convenio": { "codigo": 0, "nome": "string" }
            }
          ]
        }
      }
    },
    "detalharPaciente": {
      "method": "GET",
      "path": "/api/v1/Pacientes/Detalhar/{codigo}",
      "response": {
        "payload": {
          "paciente": {
            "codigo": 0,
            "nome": "string",
            "dataNascimento": "DD/MM/YYYY",
            "idade": 0
          }
        }
      }
    }
  },
  "headers_obrigatorios": [
    "X-APIKEY",
    "X-APIPASSWORD",
    "X-APITIMEZONE",
    "X-APITIMEZONENAME",
    "Content-Type: application/json"
  ],
  "rate_limit": "120 requisições por minuto",
  "observacao": "Este arquivo é um sumário operacional dos endpoints usados. A especificação completa do OpenAPI 3.0.1 do ProDoctor (com todos os schemas, mais de 7000 linhas) foi recebida pelo Fernando e está disponível no portal do ProDoctor. Para futuras integrações, consultar a documentação oficial."
}
