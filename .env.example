# Variáveis de ambiente do Painel Oftalmocenter
# Copie este arquivo para `.env.local` e preencha os valores reais.
# NUNCA commite o `.env.local`.

# Chave de API fornecida pelo ProDoctor.
PRODOCTOR_API_KEY=

# Senha da chave de API.
PRODOCTOR_API_PASSWORD=

# Timezone (sempre -03:00 no Brasil).
PRODOCTOR_API_TIMEZONE=-03:00

# Nome do timezone (sempre America/Sao_Paulo).
PRODOCTOR_API_TIMEZONE_NAME=America/Sao_Paulo

# URL base da API ProDoctor. O padrão (api.prodoctor.net.br) deve servir.
# Se o ProDoctor informar uma URL diferente para a sua clínica, ajuste aqui.
PRODOCTOR_API_URL=https://api.prodoctor.net.br
